---
import SiteLayout from "../../layouts/SiteLayout.astro";
import {
  commonCopy,
  localePath,
  overviewCopy,
  supportedLocales,
  type SiteLocale,
} from "../../lib/site-copy";

export function getStaticPaths() {
  return supportedLocales.map((locale) => ({
    params: { locale },
  }));
}

const locale = Astro.params.locale as SiteLocale;
const common = commonCopy[locale];
const copy = overviewCopy[locale];
let data;
try {
  const response = await fetch("https://api.food-ninja.com/api/trees/count/");
  data = await response.json();
} catch (_error) {}
let recordsData;
try {
  const response = await fetch("https://api.food-ninja.com/api/analytics/records/count/");
  recordsData = await response.json();
} catch (_error) {}
const total_trees_planted = data?.total_planted_trees || 0;
const total_trees_label = locale === "zh-TW" ? "已復育的樹木" : "trees planted around the world";

const total_records_created = recordsData?.total_records || 0;
const total_records_label = locale === "zh-TW" ? "已幫忙追蹤的紀錄" : "records we've helped tracking";

const total_code_label_h = locale === "zh-TW" ? "被超過" : "Powered by more than";
const total_code_label_f = locale === "zh-TW" ? "行代碼驅動" : "lines of code";
const total_code_count = 27900;

const isZhTW = locale === "zh-TW";
const imgPrefix = isZhTW ? "/zh-TW/C-WEB-Goal-" : "/en/E-WEB-Goal-";
const sdgs = [
  { num: 1,  label: isZhTW ? "終結貧窮"         : "No Poverty" },
  { num: 2,  label: isZhTW ? "消除飢餓"         : "Zero Hunger" },
  { num: 3,  label: isZhTW ? "健康與福祉"       : "Good Health and Well-being" },
  { num: 8,  label: isZhTW ? "合適的工作及經濟成長" : "Decent Work and Economic Growth" },
  { num: 11, label: isZhTW ? "永續城鄉"         : "Sustainable Cities and Communities" },
  { num: 12, label: isZhTW ? "責任消費及生產"   : "Responsible Consumption and Production" },
  { num: 13, label: isZhTW ? "氣候行動"         : "Climate Action" },
  { num: 14, label: isZhTW ? "保育海洋生態"     : "Life Below Water" },
  { num: 15, label: isZhTW ? "保育陸域生態"     : "Life on Land" },
  { num: 17, label: isZhTW ? "多元夥伴關係"     : "Partnerships for the Goals" },
];
---

<SiteLayout
  locale={locale}
  title={`${copy.metaTitle} | ${common.appName}`}
  description={copy.metaDescription}
>
  <section class="page-hero">
    <div>
      <!-- <p class="eyebrow">{copy.eyebrow}</p> -->
      <h1>{copy.title}</h1>
      <p class="lead">{copy.subtitle}</p>
      <div class="hero-actions">
        <a class="btn btn--primary" href={localePath(locale, "features")}>{copy.ctaPrimary}</a>
        <a href="https://apps.apple.com/us/app/food-ninja-reduce-waste/id6759663379" rel="noreferrer noopener" target="_blank">
          <img src={common.iosDownloadLabel} alt="iOS Download" height="50px">
        </a>
        <!-- <a class="btn btn--ghost" href="https://betasignup.food-ninja.com/" target="_blank" rel="noopener noreferrer">{common.testFlightSignUpLabel}</a> -->
        <a class="btn btn--ghost" href={localePath(locale, "about/contact-us")}>{copy.ctaSecondary}</a>
      </div>
      <div class="hero-badges">
        {
          copy.quickBadges.map((badge) => (
            <span>{badge}</span>
          ))
        }
      </div>
    </div>

    <aside class="hero-visual" data-tilt>
      <div class="hero-visual__row">
        <article class="mini-card">
          <strong>{copy.visualCards.firstName}</strong>
          <small>{copy.visualCards.firstEta}</small>
        </article>
        <article class="mini-card">
          <strong>{copy.visualCards.secondName}</strong>
          <small>{copy.visualCards.secondEta}</small>
        </article>
      </div>
      <div class="hero-visual__row">
        <article class="mini-card">
          <strong>{copy.visualCards.aiLabel}</strong>
          <small>{copy.visualCards.aiSub}</small>
        </article>
        <article class="mini-card">
          <strong>{copy.visualCards.donationLabel}</strong>
          <small>{copy.visualCards.donationSub}</small>
        </article>
      </div>
      <div class="hero-visual__row">
        <article class="mini-card">
          <strong>{copy.visualCards.syncLabel}</strong>
          <small>{copy.visualCards.syncSub}</small>
        </article>
        <article class="mini-card">
          <strong>{copy.visualCards.treeLabel}</strong>
          <small>{copy.visualCards.treeSub}</small>
        </article>
      </div>
    </aside>
  </section>

  <section class="section-panel">
    <div class="kpi-grid">
      {
        copy.kpis.map((kpi) => (
          <article class="kpi-card">
            <strong>
              <span data-countup data-target={String(kpi.value)}>0</span>
              {kpi.suffix}
            </strong>
            <p>{kpi.label}</p>
          </article>
        ))
      }
      <article class="kpi-card">
        <strong>
          <span data-countup data-target={String(total_trees_planted)}>0</span>
        </strong>
        <p>{total_trees_label}</p>
      </article>
      <article class="kpi-card">
        <strong>
          <span data-countup data-target={String(total_records_created)}>0</span>
        </strong>
        <p>{total_records_label}</p>
      </article>
      <article class="kpi-card">
        <p class="kpi-prefix">{total_code_label_h}</p>
        <strong>
          <span data-countup data-target={String(total_code_count)}>0</span>
        </strong>
        <p>{total_code_label_f}</p>
      </article>
    </div>
  </section>

  <section class="section-panel">
    <h2>{copy.howTitle}</h2>
    <!-- <p class="section-intro">{copy.howIntro}</p> -->
    <div class="steps-grid">
      {
        copy.steps.map((step) => (
          <article class="step-card">
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section-panel">
    <h2>{copy.sdgTitle}</h2>
    <div class="sdg-grid">
      {sdgs.map(({ num, label }) => {
        const pad = String(num).padStart(2, "0");
        const imgSrc = `${imgPrefix}${pad}.png`;
        const href = `https://sdgs.un.org/goals/goal${num}`;
        return (
          <a
            class="sdg-card"
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            title={label}
            aria-label={`SDG ${num}: ${label}`}
          >
            <img src={imgSrc} alt={`SDG ${num} – ${label}`} loading="lazy" decoding="async" />
            <span class="sdg-card__label">{label}</span>
          </a>
        );
      })}
    </div>
  </section>

  <section class="section-panel">
    <h2>{copy.galleryTitle}</h2>
    <!-- <p class="section-intro">{copy.galleryIntro}</p> -->
    <!-- TODO: MAKE IMAGES EXPANDABLE -->
    <div class="gallery-grid">
      {
        copy.gallery.map((item) => (
          <article class="gallery-card">
            <button
              class="asset-frame"
              type="button"
              aria-label={item.title}
              data-expand-src={item.imagePath}
              data-expand-alt={item.alt}
              data-expand-caption={item.title}
            >
              <img src={item.imagePath} alt={item.alt} loading="lazy" decoding="async" />
            </button>
            <div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</SiteLayout>
